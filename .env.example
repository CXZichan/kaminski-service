APP_HOST=kaminski-service.de
APP_HOSTS=kaminski-service.de,www.kaminski-service.de
RAILS_SERVE_STATIC_FILES=true
LEGAL_RELEASE_READY=false

# Docker Compose setzt diese Werte selbst im web-Service.
# Für lokale Nutzung ohne Docker bei Bedarf passend setzen:
# DATABASE_HOST=localhost
# DATABASE_PORT=5432
# DATABASE_USERNAME=postgres
# DATABASE_PASSWORD=postgres

CONTACT_RECIPIENT_EMAIL=angebote@kaminski-service.de
DEFAULT_FROM_EMAIL=website@kaminski-service.de
CONTACT_RETENTION_DAYS=90

SMTP_ADDRESS=smtp.example.invalid
SMTP_PORT=587
SMTP_DOMAIN=kaminski-service.de
SMTP_USERNAME=bitte-eintragen
SMTP_PASSWORD=bitte-eintragen
SMTP_AUTHENTICATION=plain
SMTP_ENABLE_STARTTLS_AUTO=true

ACTIVE_RECORD_ENCRYPTION_PRIMARY_KEY=bitte-mit-bin-rails-db-encryption-init-erzeugen
ACTIVE_RECORD_ENCRYPTION_DETERMINISTIC_KEY=bitte-mit-bin-rails-db-encryption-init-erzeugen
ACTIVE_RECORD_ENCRYPTION_KEY_DERIVATION_SALT=bitte-mit-bin-rails-db-encryption-init-erzeugen

ENABLE_ANALYTICS=false
ENABLE_EXTERNAL_MEDIA=false
